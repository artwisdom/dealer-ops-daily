# Copy to .env and fill in real values. .env is gitignored.

# Anthropic — required for ranking + drafting
ANTHROPIC_API_KEY=

# beehiiv — required for publishing + analytics pulls
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Replicate — optional (Flux hero images). Pipeline falls back to Pexels stock if unset.
REPLICATE_API_TOKEN=

# Pexels — optional fallback for hero images
PEXELS_API_KEY=

# Supabase — optional. If unset, affiliates load from local JSON file (data/affiliates.json).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Sheets — optional. If unset, analytics writes to local data/analytics.json
GOOGLE_SHEETS_CREDENTIALS_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Behavior flags
DRY_RUN=false                  # if true, no external sends, no API costs incurred
ISSUE_OUTPUT_DIR=issues        # where rendered issues are saved
SOURCES_FILE=sources.yaml      # source list location
SYSTEM_PROMPT_FILE=prompts/system-prompt-v1.md
